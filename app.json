{
  "expo": {
    "name": "Sophia — Σοφία",
    "slug": "sophia-christian-wisdom",
    "version": "1.0.0",
    "description": "Sagesse chrétienne au quotidien — citations, chapelet, calendrier liturgique et méditations.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sophia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F0B18"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sophia.christianwisdom",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "NSMicrophoneUsageDescription": "Sophia n'utilise pas le microphone.",
        "CFBundleDisplayName": "Sophia"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "package": "com.sophia.christianwisdom",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F0B18"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0F0B18",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/sophia-christian-wisdom"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed10aea2-7dac-49ce-9c44-fc3b5186bf3f"
      }
    },
    "owner": "charif759491",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ed10aea2-7dac-49ce-9c44-fc3b5186bf3f"
    }
  }
}
